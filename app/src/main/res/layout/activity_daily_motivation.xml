<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6F7"
    android:id="@+id/main"
    tools:context=".DailyMotivation">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Daily Motivation"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#2E7D32"
            android:gravity="center"
            android:layout_marginBottom="16dp"/>

        <!-- Image -->
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:src="@drawable/image1"
            android:scaleType="centerCrop"
            android:layout_marginBottom="16dp"/>

        <!-- Motivation Quote Box -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:elevation="4dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="“The secret of getting ahead is getting started.” – Mark Twain\n\nStart your day with small steps and keep moving forward!"
                android:textSize="18sp"
                android:lineSpacingExtra="5dp"/>
        </LinearLayout>

        <!-- Button -->
        <Button
            android:id="@+id/btnNextMotivation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Get Another Quote"
            android:backgroundTint="#4CAF50"
            android:textColor="#FFFFFF"/>

    </LinearLayout>
</LinearLayout>