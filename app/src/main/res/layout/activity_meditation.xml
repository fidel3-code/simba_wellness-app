<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6F7"
    android:id="@+id/main"
    tools:context=".Meditation">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Meditation"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#2E7D32"
            android:gravity="center"
            android:layout_marginBottom="16dp"/>

        <!-- Image -->
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:src="@drawable/img"
            android:scaleType="centerCrop"
            android:layout_marginBottom="16dp"/>

        <!-- Content Box -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:elevation="4dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Meditation is a powerful practice for enhancing mental clarity and emotional stability.\n\nBy focusing on the present moment and observing thoughts without judgment, it helps lower cortisol levels and significantly reduces chronic stress.\n\nRegular meditation has been shown to improve attention span, boost memory, and foster a greater sense of empathy and self-awareness.\n\nIncorporating just ten minutes of mindfulness into your daily routine can lead to long-term improvements in sleep quality and overall psychological resilience."
                android:textSize="18sp"
                android:lineSpacingExtra="5dp"/>
        </LinearLayout>

        <!-- Button -->
        <Button
            android:id="@+id/btnStartMeditation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Start Meditation"
            android:backgroundTint="#4CAF50"
            android:textColor="#FFFFFF"/>

    </LinearLayout>
</ScrollView>